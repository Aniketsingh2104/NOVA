<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:gravity="center_horizontal"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NOVA"
        android:textSize="48sp"
        android:textColor="@color/nova_purple"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:layout_marginTop="40dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your offline AI voice controller"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="4dp"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="24dp">

        <View
            android:id="@+id/indicatorDot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/dot_green"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NOVA is active"
            android:textSize="15sp"
            android:textColor="@color/text_primary"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/cardAccessibility"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/warning_bg"
        android:padding="14dp"
        android:layout_marginTop="20dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enable Accessibility Service for full control"
            android:textColor="@color/warning_text"
            android:textSize="13sp"/>

        <Button
            android:id="@+id/btnEnableAccessibility"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Enable Now"
            android:textSize="12sp"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

    <Button
        android:id="@+id/btnToggleNova"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:text="Pause NOVA"
        android:textSize="15sp"
        android:layout_marginTop="28dp"/>

    <Button
        android:id="@+id/btnWakeWord"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:text="Set Wake Word"
        android:textSize="15sp"
        android:layout_marginTop="12dp"
        style="@style/Widget.Material3.Button.OutlinedButton"/>

    <Button
        android:id="@+id/btnSettings"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:text="Settings"
        android:textSize="15sp"
        android:layout_marginTop="12dp"
        style="@style/Widget.Material3.Button.OutlinedButton"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Try saying..."
        android:textSize="12sp"
        android:textColor="@color/text_muted"
        android:layout_marginTop="32dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="&quot;Call Rahul&quot; &#x2022; &quot;Open YouTube&quot; &#x2022; &quot;Volume up&quot;"
        android:textSize="13sp"
        android:textColor="@color/nova_purple"
        android:gravity="center"
        android:layout_marginTop="6dp"/>

</LinearLayout>