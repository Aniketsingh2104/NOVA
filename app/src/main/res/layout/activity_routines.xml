<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg_dark" android:padding="16dp">
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Scheduled routines run automatically at set times or when you arrive at a location."
        android:textSize="13sp" android:textColor="@color/text_secondary"
        android:lineSpacingMultiplier="1.4" android:layout_marginBottom="16dp"/>
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerRoutines"
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>
    <Button android:id="@+id/btnAddRoutine" android:layout_width="match_parent"
        android:layout_height="52dp" android:text="Add routine"
        android:textSize="15sp" android:layout_marginTop="12dp"/>
</LinearLayout>